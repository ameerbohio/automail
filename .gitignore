# Secrets & certificates (never commit the generated material -- the
# generator scripts under infra/certs/*.sh are tracked, the key/cert
# output they produce is not)
.env
.env.*
!.env.example
*.pem
*.key
*.srl
infra/certs/*
!infra/certs/*.sh
!infra/certs/.gitkeep

# Go
bin/
*.test
*.out
/services/cloud/cloud
/services/printer/printer

# Node / Next.js
node_modules/
.next/
out/
npm-debug.log*
yarn-error.log*

# Data volumes / local state
*.log
data/

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp

# Claude local settings (machine-specific)
.claude/settings.local.json

# TypeScript incremental build info (generated by tsc --noEmit)
*.tsbuildinfo

# Vitest coverage output
services/portal/coverage/

# Regenerated crypto-contract vectors (Goal T2); fixture.json IS committed
testdata/crypto-contract/*.vector.json
