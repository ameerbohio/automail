# Copy to .env and fill in real values. .env is gitignored.
# Generate certs/keys with the scripts in infra/certs/ before first run:
#   ./infra/certs/gen.sh                                    (internal mTLS PKI)
#   ./infra/certs/gen-jwt-keys.sh                            (JWT RS256 keypair)
#   PRINTER_KEY_PASSPHRASE=... ./infra/certs/gen-printer-keys.sh   (printer doc keypair)
#   ./infra/certs/gen-edge-certs.sh                          (browser-facing edge TLS cert)
# The edge cert is what the Traefik front door serves for https://automail.local,
# https://api.automail.local and https://blob.automail.local -- without it,
# sniStrict rejects the handshake (ERR_SSL_UNRECOGNIZED_NAME_ALERT). It is
# self-signed, so browsers show a one-time "not secure" warning; that is expected
# for this deploy target.
#
# For a first deploy, follow docs/deploy-checklist.md -- it orders these steps and
# lists the host prerequisites. `make deploy-smoke` checks the same things.

# Postgres
POSTGRES_USER=automail
POSTGRES_PASSWORD=changeme
POSTGRES_DB=automail

# Redis
# NOT WIRED UP YET (found by the Goal T12 deploy audit). The redis service runs
# without `requirepass` and REDIS_URL carries no password, so setting this buys
# nothing today -- Redis is reachable unauthenticated by anything on the internal
# `automail` Docker network, which is not published to the host. Kept here so the
# gap is visible rather than implied-secure. Turning it on is an owner decision
# (docs/study/00-interview-pending-questions.md): it means adding `--requirepass`
# to the redis command and the credential to REDIS_URL on every consumer.
REDIS_PASSWORD=changeme

# MinIO
MINIO_ROOT_USER=automail
MINIO_ROOT_PASSWORD=changeme123
# format: <key-name>:<32-byte base64 key>, e.g. output of `openssl rand -base64 32`
MINIO_KMS_SECRET_KEY=automail-sse-key:CHANGEME_BASE64_32_BYTES

# Object storage as the BROWSER sees it. The guest's ciphertext PUT goes straight
# from the browser to the pre-signed upload_url (the cloud server never receives
# the blob), so this must be a host outside the Docker network can resolve --
# MINIO_ENDPOINT (`minio:9000`) is not. The defaults below match the Traefik route
# in docker-compose.yml; change them together or uploads break with no server-side
# error. Leave MINIO_CORS_ORIGIN as the portal's origin (the browser preflights
# the cross-origin PUT).
MINIO_PUBLIC_ENDPOINT=blob.automail.local
MINIO_PUBLIC_SECURE=true
MINIO_CORS_ORIGIN=https://automail.local

# This mailbox unit's identity, as provisioned in Postgres. MAILBOX_ID must be the
# `mailboxes.id` row and SLOT_ID the `mailbox_slots.id` row that belongs to it.
# SLOT_ID has no safe default: the printer falls back to the literal "slot-1",
# which never matches a real row, and the symptom is every job sitting in `queued`
# forever with no error anywhere. See docs/deploy-checklist.md §5.
DEV_MAILBOX_ID=00000000-0000-0000-0000-000000000001
SLOT_ID=

# Where Traefik publishes the edge. Leave at 80/443 on a real deploy host -- the
# browser reaches the routed hostnames on the standard ports. Only override when
# something else already holds them (WSL2: Windows does).
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443

# Cloud server / printer dev behavior
# DEV_MODE=true skips only the physical CUPS `lp` call; the full RSA/AES decrypt
# pipeline still runs (Phase 6+). Keep true on WSL2/Windows dev.
DEV_MODE=true
# The host CUPS queue name `lp` prints to when DEV_MODE=false. Read the exact
# name off the host with `lpstat -p -d` (docs/cups-host-setup.md Step 1).
PRINTER_NAME=Canon_MF240

# JWT (RS256) -- auth signing keypair, unrelated to the mTLS PKI and to the
# printer's document-decryption keypair below
JWT_PRIVATE_KEY_PATH=infra/certs/jwt-private.pem
JWT_PUBLIC_KEY_PATH=infra/certs/jwt-public.pem

# pgcrypto application-layer encryption key for PII columns (senders.email_enc,
# senders.name_enc, residents.name_enc) -- injected at runtime, never stored in the DB
APP_ENCRYPTION_KEY=changeme-app-encryption-key

# Printer document keypair (RSA-4096) -- senders wrap their AES key with the
# public half; private key file is itself encrypted at rest with this passphrase
PRINTER_PRIVATE_KEY_PATH=infra/certs/printer-private.pem
PRINTER_KEY_PASSPHRASE=changeme-printer-passphrase

# mTLS PKI (cloud server <-> printer microservice)
MTLS_CA_CERT_PATH=infra/certs/ca-cert.pem
MTLS_CLOUD_CERT_PATH=infra/certs/cloud-server-cert.pem
MTLS_CLOUD_KEY_PATH=infra/certs/cloud-server-key.pem
MTLS_PRINTER_CERT_PATH=infra/certs/printer-cert.pem
MTLS_PRINTER_KEY_PATH=infra/certs/printer-key.pem
