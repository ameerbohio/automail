# Copy to .env and fill in real values. .env is gitignored.

# Postgres
POSTGRES_USER=automail
POSTGRES_PASSWORD=changeme
POSTGRES_DB=automail

# MinIO
MINIO_ROOT_USER=automail
MINIO_ROOT_PASSWORD=changeme123

# Cloud server / printer dev behavior
# DEV_MODE=true skips real CUPS printing and RSA/AES decrypt (Phase 3+); keep true on WSL2/Windows dev.
DEV_MODE=true

# mTLS cert paths (generated by infra/certs/gen.sh, Phase 1)
TLS_CA_CERT=infra/certs/ca.pem
TLS_CLOUD_CERT=infra/certs/cloud-server.pem
TLS_CLOUD_KEY=infra/certs/cloud-server-key.pem
TLS_PRINTER_CERT=infra/certs/printer.pem
TLS_PRINTER_KEY=infra/certs/printer-key.pem
